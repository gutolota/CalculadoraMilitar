    { "id": "q-gt-2", "type": "condition", "position": { "x": 700, "y": 200 }, "data": { "field": "refractoryYears", "operator": "gt", "value": "2", "label": "Faltou 3 anos ou mais?" } },
    { "id": "a-mult-extra", "type": "action", "position": { "x": 900, "y": 400 }, "data": { "label": "Multa Refratário 3+ (Substitutiva)", "mult": 5, "amparo": "Art 178 RLSM", "multiplyByField": "refractoryYears", "subtractValue": 1 } },

    { "id": "q-eq-2", "type": "condition", "position": { "x": 500, "y": 400 }, "data": { "field": "refractoryYears", "operator": "eq", "value": "2", "label": "Faltou exatamente 2 anos?" } },
    { "id": "a-sub-5x", "type": "action", "position": { "x": 700, "y": 600 }, "data": { "label": "Multa Refratário 2 anos (Substitutiva)", "mult": 5, "amparo": "Art 178 RLSM" } },

    { "id": "q-eq-1", "type": "condition", "position": { "x": 300, "y": 600 }, "data": { "field": "refractoryYears", "operator": "eq", "value": "1", "label": "Faltou apenas 1 ano?" } },
    { "id": "a-sub-1x", "type": "action", "position": { "x": 500, "y": 800 }, "data": { "label": "Multa Refratário 1 ano", "mult": 1, "amparo": "Art 176 RLSM" } },

    { "id": "q1", "type": "condition", "position": { "x": 100, "y": 200 }, "data": { "field": "enlistmentStatus", "operator": "eq", "value": "late", "label": "Atraso no Alistamento?" } },
    { "id": "a1", "type": "action", "position": { "x": -100, "y": 400 }, "data": { "label": "Multa Atraso (1x)", "mult": 1, "amparo": "Art 176 RLSM" } }
  ],
  "edges": [
    { "id": "e-start-y", "source": "q-check-status", "sourceHandle": "yes", "target": "q-gt-2", "label": "SIM", "animated": true },
